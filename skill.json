      "wayfinder://delta-lab/screen/lending/{sort}/{limit}/{basis}",
      "wayfinder://delta-lab/screen/perp/by-asset-ids/{sort}/{limit}/{asset_ids}",
      "wayfinder://delta-lab/screen/perp/{sort}/{limit}/{basis}",
      "wayfinder://delta-lab/screen/price/by-asset-ids/{sort}/{limit}/{asset_ids}",
      "wayfinder://delta-lab/screen/price/{sort}/{limit}/{basis}",
      "wayfinder://delta-lab/top-apy/{lookback_days}/{limit}",
      "wayfinder://delta-lab/{basis_symbol}/apy-sources/{lookback_days}/{limit}",
      "wayfinder://delta-lab/{basis_symbol}/delta-neutral/{lookback_days}/{limit}",
      "wayfinder://delta-lab/{symbol}/basis",
      "wayfinder://delta-lab/{symbol}/timeseries/{series}/{lookback_days}/{limit}",
      "wayfinder://hyperliquid/book/{coin}",
      "wayfinder://hyperliquid/prices/{coin}",
      "wayfinder://hyperliquid/{label}/spot",
      "wayfinder://hyperliquid/{label}/state",
      "wayfinder://strategies/{name}",
      "wayfinder://tokens/gas/{chain_code}",
      "wayfinder://tokens/resolve/{query}",
      "wayfinder://tokens/search/{chain_code}/{query}",
      "wayfinder://wallets/{label}"
    ]
  },
  "references": [
    "references/commands.md",
    "references/contracts.md",
