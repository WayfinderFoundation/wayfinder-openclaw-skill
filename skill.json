{
  "name": "wayfinder",
  "version": "0.8.0",
  "description": "DeFi trading, yield strategies, and portfolio management via the Wayfinder Paths CLI (`poetry run wayfinder`).",
  "sdk_version": "2d5318c8b90e9a99198bf0c61138aa99acc9ad07",
  "entry": "SKILL.md",
  "commands": [
    "resource",
    "quote_swap",
    "execute",
    "hyperliquid",
    "hyperliquid_execute",
    "polymarket",
